{
  "ids": "arXiv:2407.08607",
  "title": "FlashAttention-3: Fast and Accurate Attention with Asynchrony and Low-precision",
  "venue": null,
  "authors": [
    {
      "name": "Jay Shah",
      "email": "jayhshah@colfax-intl.com",
      "affiliation": "Colfax Research"
